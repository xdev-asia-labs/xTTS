# ── Server ──────────────────────────────────────────────────────────────────
PORT=3099
LOG_LEVEL=info

# ── TTS Engine ──────────────────────────────────────────────────────────────
TTS_MAX_CHUNK=500
TTS_MAX_RETRIES=3
TTS_MAX_TEXT_LENGTH=20000
TTS_DEFAULT_VOICE=vi-VN-HoaiMyNeural
TTS_DEFAULT_RATE=+0%
TTS_CONCURRENCY=2

# ── Cache ───────────────────────────────────────────────────────────────────
TTS_CACHE_SIZE=100

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated origins. Use * for development, restrict in production.
TTS_CORS_ORIGINS=*

# ── Captions ────────────────────────────────────────────────────────────────
FPS=30
CAPTION_MAX_WORDS=6
CAPTION_MAX_GAP_FRAMES=10
